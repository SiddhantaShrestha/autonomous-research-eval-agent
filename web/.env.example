# Vercel / production: Render API origin (no trailing slash). Use ONE of these names:
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com
# NEXT_PUBLIC_API_BASE_URL=https://your-api.onrender.com
# Leave both unset for local dev (uses Next.js /api/evaluate + local Python).
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_API_BASE_URL=
